APP_ENV=local
ADMIN_PASSWORD=replace-with-a-strong-admin-password
BAILIAN_API_KEY=replace-with-your-api-key
BAILIAN_MODEL=qwen3.6-flash
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/forkfit
REDIS_URL=redis://localhost:6379/0
JOB_EXECUTOR=inline
MAX_GLOBAL_CONCURRENT_RUNS=1
MAX_USER_CONCURRENT_RUNS=1
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=replace-with-your-langsmith-key
LANGSMITH_PROJECT=forkfit
JWT_SECRET=change-this-to-a-random-secret-in-production
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3001
UPLOAD_MAX_BYTES=5242880
UPLOAD_MAX_PIXELS=12000000
UPLOAD_STORAGE_QUOTA_BYTES=536870912
