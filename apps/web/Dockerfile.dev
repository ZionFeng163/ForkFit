FROM node:20-alpine

ARG FORKFIT_API_BASE_URL=http://backend:8000
ENV FORKFIT_API_BASE_URL=$FORKFIT_API_BASE_URL

WORKDIR /app

# Install dependencies first (cached layer)
COPY package.json package-lock.json* ./
RUN npm ci

# Copy source
COPY . .

# Build for production (uses webpack, not Turbopack)
RUN npm run build

EXPOSE 3000

CMD ["npm", "start", "--", "-H", "0.0.0.0"]
