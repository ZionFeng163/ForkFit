# ===== Backend Production =====
FROM python:3.12-slim AS backend

WORKDIR /app

RUN apt-get update --fix-missing && \
    apt-get install -y --no-install-recommends gcc libpq-dev && \
    rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir \
    bcrypt confluent-kafka fastapi langgraph langsmith \
    "psycopg[binary]" python-multipart PyJWT redis sqlalchemy uvicorn

COPY src/ src/
COPY scripts/ scripts/

ENV PYTHONPATH=/app/src
EXPOSE 8000

CMD ["python", "scripts/run_api.py"]

# ===== Worker Production =====
FROM python:3.12-slim AS worker

WORKDIR /app

RUN apt-get update --fix-missing && \
    apt-get install -y --no-install-recommends gcc libpq-dev && \
    rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir \
    bcrypt confluent-kafka fastapi langgraph langsmith \
    "psycopg[binary]" python-multipart PyJWT redis sqlalchemy uvicorn

COPY src/ src/
COPY scripts/ scripts/

ENV PYTHONPATH=/app/src

CMD ["python", "scripts/run_worker.py"]

# ===== Frontend Production =====
FROM node:20-alpine AS frontend-builder

ARG FORKFIT_API_BASE_URL=http://backend:8000
ENV FORKFIT_API_BASE_URL=$FORKFIT_API_BASE_URL

WORKDIR /app
COPY apps/web/package.json apps/web/package-lock.json* ./
RUN npm ci
COPY apps/web/ .
RUN npm run build

# ===== Frontend Runner =====
FROM node:20-alpine AS frontend

ARG FORKFIT_API_BASE_URL=http://backend:8000
ENV FORKFIT_API_BASE_URL=$FORKFIT_API_BASE_URL
ENV NODE_ENV=production

WORKDIR /app
COPY --from=frontend-builder /app/.next ./.next
COPY --from=frontend-builder /app/node_modules ./node_modules
COPY --from=frontend-builder /app/package.json ./
COPY --from=frontend-builder /app/public ./public
COPY --from=frontend-builder /app/next.config.ts ./

EXPOSE 3000

CMD ["npm", "start"]
